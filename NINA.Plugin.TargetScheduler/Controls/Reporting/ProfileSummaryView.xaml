<UserControl x:Class="NINA.Plugin.TargetScheduler.Controls.Reporting.ProfileSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary Source="../Resources/Resources.xaml" />
    </UserControl.Resources>

    <StackPanel>
        <Button Width="25"
                Height="25"
                HorizontalAlignment="Left"
                Margin="0,0,0,6"
                Command="{Binding ToggleExpandCollapseCommand}"
                Style="{StaticResource BackgroundButton}"
                ToolTip="Expand/collapse all">
            <Grid>
                <Path Margin="5"
                      Data="{StaticResource SS_ExpandAllSVG}"
                      Fill="{StaticResource ButtonForegroundBrush}"
                      Stretch="Uniform"
                      Visibility="{Binding IsAllExpanded, Converter={StaticResource InverseBooleanToVisibilityCollapsedConverter}}" />
                <Path Margin="5"
                      Data="{StaticResource SS_CollapseAllSVG}"
                      Fill="{StaticResource ButtonForegroundBrush}"
                      Stretch="Uniform"
                      Visibility="{Binding IsAllExpanded, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
            </Grid>
        </Button>
        <TreeView BorderThickness="0"
                  ItemsSource="{Binding ProjectItems}">
            <TreeView.Template>
                <ControlTemplate>
                    <ScrollViewer MaxHeight="600"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsPresenter />
                    </ScrollViewer>
                </ControlTemplate>
            </TreeView.Template>
            <TreeView.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                 Color="{Binding Source={StaticResource ProfileService}, Path=ActiveProfile.ColorSchemaSettings.ColorSchema.ButtonBackgroundSelectedColor}" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                 Color="{Binding Source={StaticResource ProfileService}, Path=ActiveProfile.ColorSchemaSettings.ColorSchema.ButtonBackgroundSelectedColor}" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                                 Color="{Binding Source={StaticResource ProfileService}, Path=ActiveProfile.ColorSchemaSettings.ColorSchema.TertiaryBackgroundColor}" />
                <Style TargetType="{x:Type TreeViewItem}">
                    <Setter Property="Margin"
                            Value="0,3,0,3" />
                </Style>
            </TreeView.Resources>
        </TreeView>
    </StackPanel>
</UserControl>
